# Evidence-First Harness — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Artifact storage directory
EFH_ARTIFACT_DIR=.artifacts

# Session DB path (SQLite)
EFH_SESSION_DB_PATH=.artifacts/sessions.db

# Docker
EFH_SANDBOX_IMAGE=evidence-first-harness-sandbox:latest
EFH_SANDBOX_TIMEOUT_SECONDS=300
EFH_SANDBOX_CPU_LIMIT=2.0
EFH_SANDBOX_MEMORY_LIMIT=2g

# Network mode for sandbox (disabled, proxy, full)
EFH_SANDBOX_NETWORK_MODE=disabled

# Policy file path
EFH_POLICY_PATH=config/policies.yaml

# Model config path
EFH_MODELS_PATH=config/models.yaml

# Logging
EFH_LOG_LEVEL=INFO

# Observability
EFH_OTEL_ENABLED=false
EFH_OTEL_EXPORTER_ENDPOINT=

# GitHub integration (Phase 5+)
# GITHUB_TOKEN=

# ADK (Phase 2+)
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
